# User Configuration (auto-detected, change if needed)
UID=1000
GID=1000

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
APP_PORT=5002

################################################################################
# ---------- Old environment variables ----------
################################################################################
# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecmo_db
POSTGRES_PORT=5432

# Database URL (format: postgresql://user:password@host:port/database)
# - Hostname `db` because it is the service name in the DockerCompose
DATABASE_URL=postgresql://postgres:postgres@db:5432/ecmo_db
################################################################################

################################################################################
# ---------- New environment variables ----------
################################################################################
DB_USER=postgres
DB_PASS=postgres
DB_HOST=db  # Service name of the DockerCompose file
DB_NAME=ecmo_db
DB_PORT=5432
################################################################################

# pgAdmin Configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=80
PGADMIN_EXTERNAL_PORT=5050

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# Docker configuration
COMPOSE_PROJECT_NAME=ecmo-api