# Flask Configuration
FLASK_ENV=development  # v.s. `production`
# TODO: Fill in the flask secret key
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
API_PORT=5002

# Microsoft Entra Auth Configuration
UW_OIDC_AUTHORITY=https://login.microsoftonline.com/f6b6dd5b-f02f-441a-99a0-162ac5060bd2
UW_OIDC_CLIENT_ID=14d155c1-365a-4c1f-85e0-e9eec83641bc
# TODO: Fill in the secret
UW_OIDC_CLIENT_SECRET=

# Public URLs
FRONTEND_URL=http://localhost:8081
API_URL=http://localhost:${API_PORT}

# Frontend Expo app
APP_PORT=8081
# Use the following when not in docker compose - http://localhost:${API_PORT}/api
#EXPO_PUBLIC_API_URL=api:${API_PORT}/api
EXPO_PUBLIC_API_URL=http://localhost:${API_PORT}/api

# PostgreSQL Configuration
DB_USER=postgres
DB_PASS=postgres
# Use service name when using docker compose
DB_HOST=db
DB_PORT=5432
DB_NAME=ecmodb

# Docker compose db service
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASS}
POSTGRES_DB=${DB_NAME}
POSTGRES_PORT=${DB_PORT}

