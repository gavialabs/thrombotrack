FLASK_ENV=development  # v.s. `production`
API_PORT=5002
FLASK_SECRET_KEY=TODO_UPDATE_WITH_FLASK_SECRET_KEY

################################################################################
# Frontend Expo app
################################################################################
APP_PORT=8081

################################################################################
# Microsoft Entra Auth Configuration
################################################################################
UW_OIDC_AUTHORITY=https://login.microsoftonline.com/f6b6dd5b-f02f-441a-99a0-162ac5060bd2
